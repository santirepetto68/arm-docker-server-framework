# .env.example — shared infrastructure configuration
# Copy to .env and fill in your values.
#
# Game-specific variables (ports, passwords, map, etc.) go in instances/<game-id>.env
# Copy instances/ark-se.env.example → instances/ark-se.env
# Copy instances/project-zomboid.env.example → instances/project-zomboid.env

COMPOSE_PROJECT_NAME=gameserver
TZ=UTC

# --- Container images ---
# INSTALL_IMAGE is used by every *-install service (SteamCMD under box64).
# RUNTIME_IMAGE is the default runtime (ARK uses this — box64 emulation).
# PZ_RUNTIME_IMAGE overrides the runtime for Project Zomboid, which needs FEX
# instead of box64 (box64's dynarec mistranslates the JVM flags PZ's launcher
# uses and crashes the JIT). FEX-2506 introduced a JNI regression (issue #4710)
# so the image must be pinned to a pre-2506 FEX build. pz-fex-arm64 is built
# from source at commit a08a6ce5 (May 2025 — 19 months of JIT fixes, 5 days
# before the regression). Build it once on the Oracle host before first use.
INSTALL_IMAGE=quintenqvd/pterodactyl_images:installer_steamcmd
RUNTIME_IMAGE=quintenqvd/pterodactyl_images:emulation
# Custom FEX image built from source at commit a08a6ce5 (May 2025, pre-2506).
# Build it first on the Oracle host: ./docker/pz-fex/build.sh
PZ_RUNTIME_IMAGE=pz-fex-arm64:latest

# --- Active game ---
# Set to a folder name under games/ (e.g. ark-se, project-zomboid)
GAME_ID=ark-se

# --- Install options ---
INSTALL_VALIDATE=0

# --- Backup retention (0 = keep all) ---
BACKUP_KEEP_LAST=0

# --- File ownership repair after install (0 = skip) ---
# If the install container runs as root but the runtime container runs as a
# non-root user, SteamCMD will leave root-owned files the runtime can't write,
# forcing a manual chown after every install/update. Setting these triggers a
# chown at the end of install-game.sh. Leave as 0/0 here (ARK runs as root);
# override per-instance in instances/<game-id>.env when a game needs it
# (Project Zomboid runs as UID 1001 under teriyakigod/steamcmd — set 1001/1001
# in instances/project-zomboid.env).
SERVER_UID=0
SERVER_GID=0
