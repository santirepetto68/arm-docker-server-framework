COMPOSE_PROJECT_NAME=arksearm
TZ=UTC

INSTALL_IMAGE=quintenqvd/pterodactyl_images:installer_steamcmd
RUNTIME_IMAGE=quintenqvd/pterodactyl_images:emulation

STEAM_USER=anonymous
STEAM_PASS=
STEAM_AUTH=
SRCDS_APPID=376030
INSTALL_VALIDATE=0
EXTRA_FLAGS=

SERVER_MAP=TheIsland
SESSION_NAME=AurumServer
SERVER_PORT=7777
RAW_SOCKET_PORT=7778
QUERY_PORT=27015
RCON_PORT=27020
MAX_PLAYERS=20

ADDITIONAL_ARGS=
CROSSPLAY=1
PUBLIC_IP_FOR_EPIC=

ARK_PASSWORD=
ARK_ADMIN_PASSWORD=CHANGE_ME

BATTLE_EYE=0

# --- Advanced / Optional ---
MODS_ENABLED=0
SYNC_CONFIG_ON_START=1
RCON_WAIT_TIMEOUT=300
MULTIHOME=
ALT_SAVE_DIRECTORY_NAME=
CLUSTER_ID=
CLUSTER_DIR_OVERRIDE=
BACKUP_KEEP_LAST=0
SERVER_UID=0
SERVER_GID=0
