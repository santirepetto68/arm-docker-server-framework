# .env.example — shared infrastructure configuration
# Copy to .env and fill in your values.
#
# Game-specific variables (ports, passwords, map, etc.) go in instances/<game-id>.env
# Copy instances/ark-se.env.example → instances/ark-se.env
# Copy instances/project-zomboid.env.example → instances/project-zomboid.env

COMPOSE_PROJECT_NAME=gameserver
TZ=UTC

# --- Container images ---
# INSTALL_IMAGE is used by every *-install service (SteamCMD under box64).
# RUNTIME_IMAGE is the default runtime (ARK uses this — box64 emulation).
# PZ_RUNTIME_IMAGE overrides the runtime for Project Zomboid, which needs FEX
# instead of box64 (box64's dynarec mistranslates the JVM flags PZ's launcher
# uses and crashes the JIT). We pin to teriyakigod/steamcmd:arm64 (Oct 2023,
# FEX ~2310) because FEX-2506 introduced a JIT regression that mistranslates
# HotSpot's JNI fast path (jni_IsInstanceOf) — see FEX issue #4710. Newer
# images (supersunho/fex-emu FEX 2601+) reproduce the crash; this older
# image predates the regression and is the known-working community choice
# (same image the joyfuI/project-zomboid-server-docker-arm64 repo uses).
INSTALL_IMAGE=quintenqvd/pterodactyl_images:installer_steamcmd
RUNTIME_IMAGE=quintenqvd/pterodactyl_images:emulation
PZ_RUNTIME_IMAGE=teriyakigod/steamcmd:arm64

# --- Active game ---
# Set to a folder name under games/ (e.g. ark-se, project-zomboid)
GAME_ID=ark-se

# --- Install options ---
INSTALL_VALIDATE=0

# --- Backup retention (0 = keep all) ---
BACKUP_KEEP_LAST=0

# --- File ownership repair after install (0 = skip) ---
SERVER_UID=0
SERVER_GID=0
