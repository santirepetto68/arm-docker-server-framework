# instances/project-zomboid.env.example — Project Zomboid instance configuration
# Copy to instances/project-zomboid.env and fill in your values.
# These are loaded alongside .env for the project-zomboid and project-zomboid-install services.

# --- SteamCMD ---
STEAM_USER=anonymous
STEAM_PASS=
STEAM_AUTH=
EXTRA_FLAGS=

# --- Server identity ---
# Must be alphanumeric + underscores only (used as the save/config folder name).
# Config files in games/project-zomboid/config/ must be named to match (e.g. myserver.ini).
SERVER_NAME=servertest
MAX_PLAYERS=10

# --- Network ports ---
PZ_SERVER_PORT=16261
PZ_STEAM_PORT=16262

# --- Authentication ---
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME

# --- Startup behaviour ---
SYNC_CONFIG_ON_START=1
# Set NO_STEAM=1 to disable Steam integration (VAC, Workshop). LAN-only use.
NO_STEAM=0

# --- Mods (Steam Workshop) ---
MODS_ENABLED=0
# Comma-separated mod IDs (from the mod's Workshop page, e.g. 2392987739)
MODS=
# Comma-separated Workshop item IDs (usually same as MODS)
MOD_WORKSHOP_IDS=

# --- JVM heap / GC ---
# PZ's shell launcher reads JVM flags from ProjectZomboid64.json in the install
# dir (data/project-zomboid/ProjectZomboid64.json). Edit that file to change
# -Xms / -Xmx / GC. Defaults are sensible; PZ recommends at least 4G heap.

# --- FEX-Emu ---
# Rootfs resolution order (games/project-zomboid/game.sh):
#   1. FEX_ROOTFS_PATH (explicit dir, e.g. a shared host mount)
#   2. image-bundled /opt/fex-rootfs (supersunho/fex-emu ships one)
#   3. on-demand download — uses FEX_ROOTFS_DISTRO, requires curl/python3/unsquashfs
# Usually you leave both unset and rely on the bundled rootfs.
# FEX_ROOTFS_PATH=
# Valid FEX_ROOTFS_DISTRO keys (from FEX catalog): "Ubuntu 20.04", "Ubuntu 22.04",
# "Ubuntu 22.10", "Ubuntu 23.04", "Ubuntu 23.10", "Ubuntu 24.04",
# "Fedora 38/40/43", "ArchLinux".
FEX_ROOTFS_DISTRO="Ubuntu 22.04"

# --- File ownership ---
# teriyakigod/steamcmd:arm64 (and supersunho/fex-emu) run as UID 1001. The
# install container (quintenqvd/pterodactyl_images:installer_steamcmd) runs as
# root, so without these overrides every install/update leaves root-owned
# files the runtime can't write. install-game.sh reads these and chown -Rs
# /mnt/server at the end of install. Override in .env's 0/0 default.
SERVER_UID=1001
SERVER_GID=1001

# --- Optional / advanced ---
ADDITIONAL_ARGS=
