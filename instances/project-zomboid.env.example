# instances/project-zomboid.env.example — Project Zomboid instance configuration
# Copy to instances/project-zomboid.env and fill in your values.
# These are loaded alongside .env for the project-zomboid and project-zomboid-install services.

# --- SteamCMD ---
STEAM_USER=anonymous
STEAM_PASS=
STEAM_AUTH=
EXTRA_FLAGS=

# --- Server identity ---
# Must be alphanumeric + underscores only (used as the save/config folder name).
# Config files in games/project-zomboid/config/ must be named to match (e.g. myserver.ini).
SERVER_NAME=servertest
MAX_PLAYERS=10

# --- Network ports ---
PZ_SERVER_PORT=16261
PZ_STEAM_PORT=16262

# --- Authentication ---
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME

# --- Startup behaviour ---
SYNC_CONFIG_ON_START=1
# Set NO_STEAM=1 to disable Steam integration (VAC, Workshop). LAN-only use.
NO_STEAM=0

# --- Mods (Steam Workshop) ---
MODS_ENABLED=0
# Comma-separated mod IDs (from the mod's Workshop page, e.g. 2392987739)
MODS=
# Comma-separated Workshop item IDs (usually same as MODS)
MOD_WORKSHOP_IDS=

# --- JVM heap / GC ---
# PZ's shell launcher reads JVM flags from ProjectZomboid64.json in the install
# dir (data/project-zomboid/ProjectZomboid64.json). Edit that file to change
# -Xms / -Xmx / GC. Defaults are sensible; PZ recommends at least 4G heap.

# --- FEX-Emu ---
# Workaround for "FATAL: kernel too old" from the rootfs glibc when FEX
# reports a low OS ABI version. Bump if the default still fails.
FEX_KERNELVERSION=6.1
# Optional shared rootfs path (ends with /). Empty = use image-bundled rootfs.
FEX_ROOTFS_PATH=

# --- Optional / advanced ---
ADDITIONAL_ARGS=
