# instances/ark-se.env.example — ARK: Survival Evolved instance configuration
# Copy to instances/ark-se.env and fill in your values.
# These are loaded alongside .env for the ark-se and ark-install services.

# --- SteamCMD ---
STEAM_USER=anonymous
STEAM_PASS=
STEAM_AUTH=
EXTRA_FLAGS=

# --- Server identity ---
SESSION_NAME=My ARK Server
SERVER_MAP=TheIsland
MAX_PLAYERS=20

# --- Network ports ---
SERVER_PORT=7777
RAW_SOCKET_PORT=7778
QUERY_PORT=27015
RCON_PORT=27020

# --- Authentication ---
ARK_PASSWORD=
ARK_ADMIN_PASSWORD=CHANGE_ME

# --- Epic / crossplay ---
CROSSPLAY=1
PUBLIC_IP_FOR_EPIC=

# --- Features ---
BATTLE_EYE=0
MODS_ENABLED=0

# --- Startup behaviour ---
SYNC_CONFIG_ON_START=1
# How long (seconds) to wait for RCON before proceeding with server startup
RCON_WAIT_TIMEOUT=300

# --- Optional / advanced ---
ADDITIONAL_ARGS=
MULTIHOME=
ALT_SAVE_DIRECTORY_NAME=
CLUSTER_ID=
CLUSTER_DIR_OVERRIDE=
