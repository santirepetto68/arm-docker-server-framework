# game.env — Project Zomboid dedicated server metadata
# Sourced by scripts/install-game.sh and scripts/start-game.sh

# Identity
GAME_ID=project-zomboid
GAME_NAME="Project Zomboid"
SRCDS_APPID=380870

# Paths (relative to /mnt/server)
# We run the stock ProjectZomboid64 shell launcher under FEX-Emu. The
# launcher reads JVM flags from ProjectZomboid64.json in the install dir —
# tune heap/GC there. Running the launcher directly (rather than invoking
# jre64/bin/java with a curated flag set) is what Quinten's Q_eggs ARM64
# egg does, and FEX handles the launcher's JVM flags correctly.
GAME_BINARY="ProjectZomboid64"
GAME_WORKING_DIR="."
# Config and saves live under the cachedir, which we set to /mnt/server/.cache.
# When -cachedir is passed explicitly, PZ treats it as the root and does NOT
# insert a `Zomboid/` subdir (that only happens when -cachedir is unset and PZ
# anchors to $HOME/Zomboid).
GAME_CONFIG_DIR=".cache/Server"
# backup-game.sh tars this entire subtree; .cache/ covers world chunks
# (Saves/), player DB (Server/db/), and logs — all in one archive.
GAME_SAVE_DIR=".cache"
GAME_LOG_DIR=".cache/Logs"

# Emulator. FEX-Emu is required for PZ on ARM64: box64's dynarec mistranslates
# the JVM flags PZ's launcher uses (ZGC, compressed oops), causing repeated
# SIGSEGVs at the same translated block address. FEX does not have this issue.
# The runtime image (see docker-compose.yml) must be one with FEX installed.
#
# FEXInterpreter is the actual ELF loader. On teriyakigod/steamcmd:arm64 (our
# pinned image) it lives at /usr/bin/FEXInterpreter. Alternative images put it
# elsewhere (supersunho uses /usr/local/fex/bin/) — adjust if swapping images.
GAME_LAUNCHER="/usr/bin/FEXInterpreter"

# Config files to sync from games/project-zomboid/config/ → GAME_CONFIG_DIR on start.
# PZ names its config files after SERVER_NAME (e.g. servertest.ini → ${SERVER_NAME}.ini).
# The value below is evaluated after SERVER_NAME is loaded, so keep the ${} literals.
GAME_CONFIG_FILES="${SERVER_NAME:-servertest}.ini ${SERVER_NAME:-servertest}_SandboxVars.lua"

# Shutdown — no RCON in Project Zomboid; signal-based only
GAME_SHUTDOWN_STRATEGY="signal"
GAME_SHUTDOWN_GRACE_SECONDS=30

# Health check — PID-only (no RCON in PZ)
GAME_HEALTHCHECK_STRATEGY="pid"

# Mod support via Steam Workshop (-mods flag)
GAME_SUPPORTS_MODS=1

# Defaults
GAME_DEFAULT_MAX_PLAYERS=10

# SteamCMD depot selection — PZ ships the bundled JRE only in the Linux depot.
# Under emulation SteamCMD can misdetect the platform; force it explicitly.
STEAMCMD_PLATFORM_TYPE="linux"
