# ARK: Survival Evolved — Game Module Metadata
# Sourced by generic scripts (install-game.sh, start-game.sh, backup-game.sh).
# Do not put user-specific values here; those belong in .env or instances/*.env.

# Identity
GAME_ID=ark-se
GAME_NAME="ARK: Survival Evolved"
SRCDS_APPID=376030

# Paths (relative to /mnt/server)
GAME_BINARY="ShooterGame/Binaries/Linux/ShooterGameServer"
GAME_WORKING_DIR="ShooterGame/Binaries/Linux"
GAME_CONFIG_DIR="ShooterGame/Saved/Config/LinuxServer"
GAME_SAVE_DIR="ShooterGame/Saved"
GAME_LOG_DIR="ShooterGame/Saved/Logs"

# Config files to sync from games/{id}/config/ into GAME_CONFIG_DIR on start
GAME_CONFIG_FILES="GameUserSettings.ini Game.ini"

# Shutdown
GAME_SHUTDOWN_STRATEGY="rcon-then-signal"
GAME_SHUTDOWN_GRACE_SECONDS=15

# Health check
GAME_HEALTHCHECK_STRATEGY="rcon"
GAME_RCON_PORT_VAR="RCON_PORT"
GAME_RCON_PASSWORD_VAR="ARK_ADMIN_PASSWORD"

# Defaults (can be overridden in .env or instances/*.env)
GAME_DEFAULT_MAP="TheIsland"
GAME_DEFAULT_MAX_PLAYERS=20

# Features
GAME_SUPPORTS_MODS=1
